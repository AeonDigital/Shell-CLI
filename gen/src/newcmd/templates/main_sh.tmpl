#!/usr/bin/env bash

# ==============================================================================
# SCRIPT: main.sh
# DESCRIPTION: Main entrypoint executing core routing and compilation layers.
#              Package Context: $TARGET_PKG
# ==============================================================================

# Export active packaging identity descriptors to downstream engine blocks
export SHELL_CLI_CMD_ROOT_PATH="$(cd "$(dirname "${BASH_SOURCE}")" && pwd)"
export SHELL_CLI_CMD_ACTIVE_PKG="${TARGET_PKG}"



# Load active corporate shared runtime infrastructure components
if [ -f "${SHELL_CLI_CMD_ROOT_PATH}/globals/utils.sh" ]; then
  . "${SHELL_CLI_CMD_ROOT_PATH}/globals/utils.sh"
else
  echo "[ERR] Critical Core Fault :: Corporate shared runtime utilities are missing at '${SHELL_CLI_CMD_ROOT_PATH}/globals/utils.sh'."
  exit 1
fi



# Ensure engine package binary files dependencies are present in workspace context
shell_cli_ensure_engine "$@"

# Automatically source global assets followed by targeted sub-command file structures
# Passing the root context path along with the absolute first operational user parameter ($1)
if ! shell_cli_source_dir "${SHELL_CLI_ROOT_PATH}" "$1"; then
  exit 1
fi

# Pass control directly to the central execution coordinator.
shell_cli_run "${SHELL_CLI_ACTIVE_PKG}" "$@"